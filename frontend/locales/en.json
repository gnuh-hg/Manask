    "feat_tag": "Features",
    "feat_title": "Everything you need, one place",
    "feat_desc": "From organizing tasks and focusing with Pomodoro, to AI analysis and progress tracking — Manask handles it all.",
    "feat1_title": "Task Manager",
    "feat1_desc": "3-level hierarchy: Folder → Project → Task. Each task has priority, due date, notes and time spent. Filter, sort and freely drag-and-drop.",
    "feat2_title": "Pomodoro Timer",
    "feat2_desc": "3 modes: Focus / Short Break / Long Break, fully customizable durations. Pick an active task, start the timer, focus without leaving Manask.",
    "feat3_title": "Visual Analytics",
    "feat3_desc": "365-day heatmap, Line chart trends by 7d / 30d / 12m, Donut chart task distribution by project, and an overview summary.",
    "feat4_title": "AI Chatbot",
    "feat4_desc": "AI assistant with workspace context. Generate node-based roadmaps, folder-project-task trees and workload analysis — save directly into the app in one click.",
    "feat5_title": "Roadmap Editor",
    "feat5_desc": "Edit roadmaps on a node-based canvas. Connect milestones, drag to rearrange, customize edge labels. Generate from AI or build from scratch.",
    "feat_more_tag": "And more",
    "feat6_title": "Offline Support",
    "feat6_desc": "IndexedDB caches data locally. Offline requests are queued and auto-synced to the server when connection resumes.",
    "feat7_title": "Multilingual",
    "feat7_desc": "Full bilingual interface in English / Vietnamese. Instant switch from the sidebar, auto-saved per account.",
